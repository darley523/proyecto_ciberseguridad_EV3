pipeline {
    agent any
    stages {
        stage('Construcción') {
            steps {
                echo 'Construyendo imagen Docker...'
                bat 'docker build -t app-ev3 .'
            }
        }
        stage('Despliegue') {
            steps {
                echo 'Desplegando contenedor...'
                bat 'docker rm -f contenedor-app || true'
                bat 'docker run -d --name contenedor-app -p 5000:5000 app-ev3'
            }
        }
    }
}