pipeline {
    agent any
    stages {
        stage('Construcción') {
            steps {
                // Comando para construir tu app
                bat 'docker build -t app-ev3 .'
            }
        }
        stage('Despliegue') {
            steps {
                // Comando para levantar la app automáticamente
                bat 'docker rm -f contenedor-ev3 || true'
                bat 'docker run -d --name contenedor-ev3 -p 5000:5000 app-ev3'
            }
        }
    }
}